{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "plugins/**",
      "scripts/**",
      "test/**",
      "*.json",
      "!plugins/herdr-reviewr",
      "!plugins/herdr-project-switcher",
      "!plugins/herdr-jumplist",
      "!plugins/pi-subagents",
      "!plugins/mindwalk/.github",
      "!plugins/mindwalk/assets",
      "!plugins/mindwalk/cmd",
      "!plugins/mindwalk/internal",
      "!plugins/mindwalk/schema",
      "!plugins/mindwalk/testdata",
      "!plugins/mindwalk/web",
      "!**/*.generated.*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
