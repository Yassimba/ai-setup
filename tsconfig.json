{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["plugins/*/src/**/*.ts", "test/**/*.ts"],
  "exclude": ["plugins/pi-subagents/**"]
}
